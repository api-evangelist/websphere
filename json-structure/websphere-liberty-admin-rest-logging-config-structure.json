{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "LoggingConfig",
  "type": "object",
  "properties": {
    "logDirectory": {
      "type": "string"
    },
    "consoleLogLevel": {
      "type": "string"
    },
    "messageFileName": {
      "type": "string"
    },
    "traceFileName": {
      "type": "string"
    },
    "traceSpecification": {
      "type": "string"
    },
    "maxFileSize": {
      "type": "integer"
    },
    "maxFiles": {
      "type": "integer"
    }
  }
}