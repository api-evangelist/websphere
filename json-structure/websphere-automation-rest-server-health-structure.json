{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "ServerHealth",
  "type": "object",
  "properties": {
    "serverId": {
      "type": "string"
    },
    "serverName": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "uptime": {
      "type": "integer"
    },
    "cpuUsage": {
      "type": "number"
    },
    "memoryUsage": {
      "type": "number"
    },
    "openVulnerabilities": {
      "type": "integer"
    },
    "lastHealthCheck": {
      "type": "string"
    },
    "checks": {
      "type": "array"
    }
  }
}