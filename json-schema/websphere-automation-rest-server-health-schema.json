{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ServerHealth",
  "type": "object",
  "properties": {
    "serverId": {
      "type": "string"
    },
    "serverName": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "uptime": {
      "type": "integer",
      "description": "Uptime in seconds"
    },
    "cpuUsage": {
      "type": "number",
      "description": "CPU usage percentage"
    },
    "memoryUsage": {
      "type": "number",
      "description": "Memory usage percentage"
    },
    "openVulnerabilities": {
      "type": "integer"
    },
    "lastHealthCheck": {
      "type": "string"
    },
    "checks": {
      "type": "array"
    }
  }
}