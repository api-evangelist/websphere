{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LogMessage",
  "title": "LogMessage",
  "type": "object",
  "properties": {
    "datetime": {
      "type": "string",
      "format": "date-time",
      "example": "2026-01-15T10:30:00Z"
    },
    "level": {
      "type": "string",
      "example": "example_value"
    },
    "message": {
      "type": "string",
      "example": "example_value"
    },
    "logger": {
      "type": "string",
      "example": "example_value"
    },
    "thread": {
      "type": "string",
      "example": "example_value"
    },
    "sequence": {
      "type": "string",
      "example": "example_value"
    }
  }
}