{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/LibertyApplicationStatus",
  "title": "LibertyApplicationStatus",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "state": {
      "type": "string",
      "enum": [
        "STARTED",
        "STOPPED",
        "STARTING",
        "STOPPING"
      ],
      "example": "STARTED"
    },
    "message": {
      "type": "string",
      "example": "example_value"
    }
  }
}