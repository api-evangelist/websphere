{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ApplicationStatus",
  "title": "ApplicationStatus",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "status": {
      "type": "string",
      "enum": [
        "started",
        "stopped",
        "starting",
        "stopping"
      ],
      "example": "started"
    },
    "message": {
      "type": "string",
      "example": "example_value"
    }
  }
}