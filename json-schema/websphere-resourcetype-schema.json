{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ResourceType",
  "title": "ResourceType",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "example": "Example Title"
    },
    "description": {
      "type": "string",
      "example": "A sample description."
    },
    "href": {
      "type": "string",
      "format": "uri",
      "example": "https://www.example.com"
    }
  }
}