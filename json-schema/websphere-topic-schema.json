{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/Topic",
  "title": "Topic",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Administrative topic object name",
      "example": "Example Title"
    },
    "topicString": {
      "type": "string",
      "description": "Topic string",
      "example": "example_value"
    },
    "description": {
      "type": "string",
      "example": "A sample description."
    },
    "type": {
      "type": "string",
      "enum": [
        "local",
        "cluster"
      ],
      "example": "local"
    },
    "durableSubscriptions": {
      "type": "string",
      "enum": [
        "allowed",
        "inhibited"
      ],
      "example": "allowed"
    },
    "publish": {
      "type": "string",
      "enum": [
        "allowed",
        "inhibited"
      ],
      "example": "allowed"
    },
    "subscribe": {
      "type": "string",
      "enum": [
        "allowed",
        "inhibited"
      ],
      "example": "allowed"
    }
  }
}