{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/HealthCheckResponse",
  "title": "HealthCheckResponse",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "UP",
        "DOWN"
      ],
      "example": "UP"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Health check name"
          },
          "status": {
            "type": "string",
            "enum": [
              "UP",
              "DOWN"
            ]
          },
          "data": {
            "type": "object",
            "additionalProperties": true,
            "description": "Additional health check data"
          }
        }
      },
      "example": []
    }
  }
}